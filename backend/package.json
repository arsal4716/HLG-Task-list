{
  "name": "hlg-task-management-backend",
  "version": "1.0.0",
  "description": "HLG Team - Internal Task Management System (Backend)",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node utils/seeder.js",
    "client:install": "npm --prefix frontend install",
    "client:build": "npm --prefix frontend run build",
    "build": "npm run client:install && npm run client:build",
    "deploy": "npm install && npm run build && npm start"
  },
  "keywords": [
    "task-management",
    "mern",
    "express",
    "mongodb"
  ],
  "author": "HLG Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.14",
    "socket.io": "^4.7.5",
    "validator": "^13.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
